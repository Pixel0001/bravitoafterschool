// ==================== PROBLEM BANK ====================

model Problem {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  description    String           // Cerința problemei (markdown)
  difficulty     ProblemDifficulty @default(EASY)
  topic          String           // ex: "loops", "arrays", "functions"
  subtopic       String?
  type           ProblemType      @default(MULTIPLE_CHOICE)

  // Pentru MULTIPLE_CHOICE: array de variante; correctAnswer = textul corect
  // Pentru CODING: starterCode opțional; expectedOutput sau testCases
  // Pentru SHORT_ANSWER / IO: correctAnswer e răspunsul exact (case-insensitive trim)
  options        String[]         @default([])  // doar pentru grilă
  correctAnswer  String?          // răspunsul corect (text/literă/output)
  starterCode    String?          // pentru coding
  testCases      Json?            // [{ input, expectedOutput }] pentru coding (opțional)

  explanation    String           // EXPLICAȚIA — pas cu pas, AI-like
  hint           String?          // Hint progresiv

  tags           String[]         @default([])
  estimatedTime  Int              @default(5)   // minute
  points         Int              @default(10)
  language       String?          // "python", "javascript" etc. pentru coding

  courseId       String?          @db.ObjectId  // opțional: legat de un curs
  lessonId       String?          @db.ObjectId  // opțional: aparține unei lecții dintr-un modul
  lessonOrder    Int?                            // ordinea în lecție
  active         Boolean          @default(true)

  createdById    String?          @db.ObjectId
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  course         Course?          @relation(fields: [courseId], references: [id], onDelete: SetNull)
  lesson         Lesson?          @relation("LessonProblems", fields: [lessonId], references: [id], onDelete: SetNull)
  createdBy      User?            @relation("CreatedProblems", fields: [createdById], references: [id], onDelete: SetNull)
  attempts       ProblemAttempt[]
  setProblems    SetProblem[]
  submissions    ProblemSubmission[]

  @@index([difficulty, topic, active])
  @@index([topic])
  @@index([lessonId, lessonOrder])
  @@map("problems")
}

enum ProblemDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ProblemType {
  MULTIPLE_CHOICE   // grilă (o singură variantă corectă)
  MULTIPLE_SELECT   // grilă cu mai multe variante corecte (checkbox)
  SHORT_ANSWER      // răspuns scurt text
  CODING            // cod
  INPUT_OUTPUT      // I/O — verifică output exact
}

model GeneratedSet {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  studentId      String?       @db.ObjectId   // opțional - poate fi un set fără elev anume
  config         Json?         // { difficulty, topic, count, mix } - cum a fost generat
  
  // Politica afișării explicațiilor
  explanationPolicy ExplanationPolicy @default(AFTER_ANSWER)

  // Token unic pentru link public (elevul accesează fără cont)
  accessToken    String        @unique

  timeLimit      Int?          // minute (opțional)
  startedAt      DateTime?
  completedAt    DateTime?

  createdById    String?       @db.ObjectId
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  student        Student?      @relation(fields: [studentId], references: [id], onDelete: SetNull)
  createdBy      User?         @relation("CreatedSets", fields: [createdById], references: [id], onDelete: SetNull)
  setProblems    SetProblem[]
  attempts       ProblemAttempt[]

  @@index([studentId])
  @@map("generated_sets")
}

enum ExplanationPolicy {
  ALWAYS         // ✅ Vezi oricând
  AFTER_ANSWER   // ❌ Doar după ce răspunzi
  AFTER_SET      // ❌ Doar după ce termini setul
}

model SetProblem {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  setId       String       @db.ObjectId
  problemId   String       @db.ObjectId
  order       Int          @default(0)

  set         GeneratedSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  problem     Problem      @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([setId, problemId])
  @@map("set_problems")
}

model ProblemAttempt {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId   String?  @db.ObjectId
  problemId   String   @db.ObjectId
  setId       String?  @db.ObjectId

  answer      String   // ce a trimis elevul
  isCorrect   Boolean  @default(false)
  attempts    Int      @default(1)   // câte încercări la această problemă
  timeSpent   Int      @default(0)   // secunde
  pointsAwarded Int    @default(0)
  
  createdAt   DateTime @default(now())

  student     Student?       @relation(fields: [studentId], references: [id], onDelete: SetNull)
  problem     Problem        @relation(fields: [problemId], references: [id], onDelete: Cascade)
  set         GeneratedSet?  @relation(fields: [setId], references: [id], onDelete: SetNull)

  @@index([studentId, problemId])
  @@index([setId])
  @@index([problemId])
  @@map("problem_attempts")
}

