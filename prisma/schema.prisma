  chestId     String    @db.ObjectId
  cosmeticId  String?   @db.ObjectId         // nullable pentru reward de gems/coins
  weight      Int       @default(10)         // probabilitate relativă
  // Reward alternativ pentru currency drop
  coinsAmount Int?
  gemsAmount  Int?
  createdAt   DateTime  @default(now())

  chest       Chest     @relation(fields: [chestId], references: [id], onDelete: Cascade)
  cosmetic    Cosmetic? @relation(fields: [cosmeticId], references: [id], onDelete: SetNull)

  @@index([chestId])
  @@map("chest_rewards")
}

model ChestOpening {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  studentId       String    @db.ObjectId
  chestId         String    @db.ObjectId
  rewardCosmeticId String?  @db.ObjectId
  rewardCoins     Int?
  rewardGems      Int?
  createdAt       DateTime  @default(now())

  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  chest           Chest     @relation(fields: [chestId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@map("chest_openings")
}

// ==================== LEADERBOARD EVENTS ====================

enum LeaderboardType {
  XP
  CODING
  GEMS
  COINS
}

model LeaderboardEvent {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  type        LeaderboardType     @default(XP)
  startsAt    DateTime
  endsAt      DateTime
  active      Boolean             @default(true)
  // Vizual
  bannerUrl   String?
  themeColor  String?             // hex
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  entries     LeaderboardEntry[]
  rewards     LeaderboardReward[]

  @@index([active, endsAt])
  @@map("leaderboard_events")
}

model LeaderboardEntry {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  eventId     String           @db.ObjectId
  studentId   String           @db.ObjectId
  score       Int              @default(0)
  rank        Int?
  updatedAt   DateTime         @updatedAt
  createdAt   DateTime         @default(now())

  event       LeaderboardEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student     Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentId])
  @@index([eventId, score])
  @@map("leaderboard_entries")
}

model LeaderboardReward {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  eventId     String           @db.ObjectId
  rank        Int              // 1, 2, 3, ... sau 0 = top10, etc.
  rankTo      Int?             // dacă vrei range (ex 4-10)
  // Tipul de reward (oricare combinație)
  xp          Int?             // XP acordat ca recompensă
  coins       Int?
  gems        Int?
  cosmeticId  String?          @db.ObjectId
  chestId     String?          @db.ObjectId
  title       String?
  customReward String?         // Recompensă liberă: "Gift card Steam $10", "Lecție gratuită", etc.
  createdAt   DateTime         @default(now())

  event       LeaderboardEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  claims      RewardClaim[]

  @@index([eventId, rank])
  @@map("leaderboard_rewards")
}

model RewardClaim {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  studentId   String            @db.ObjectId
  rewardId    String            @db.ObjectId
  claimedAt   DateTime          @default(now())

  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reward      LeaderboardReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@unique([studentId, rewardId])
  @@map("reward_claims")
}

