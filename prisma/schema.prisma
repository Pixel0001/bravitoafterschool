  createdAt   DateTime @default(now())

  student     Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  module      LearningModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([studentId, moduleId])
  @@map("module_advances")
}

model ModuleHidden {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId   String   @db.ObjectId
  moduleId    String   @db.ObjectId
  createdAt   DateTime @default(now())

  student     Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  module      LearningModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([studentId, moduleId])
  @@map("module_hidden")
}

model LessonAccess {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId   String   @db.ObjectId
  lessonId    String   @db.ObjectId
  grantedById String?  @db.ObjectId
  notes       String?
  createdAt   DateTime @default(now())

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@map("lesson_accesses")
}

model LessonProgress {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  studentId           String    @db.ObjectId
  lessonId            String    @db.ObjectId
  theoryCompleted     Boolean   @default(false)
  currentProblemIndex Int       @default(0)
  hintsUsed           String[]  @default([]) // problemId-uri pentru care s-a apăsat hint
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  student             Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson              Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@index([studentId])
  @@map("lesson_progresses")
}

model ProblemSubmission {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  studentId   String           @db.ObjectId
  problemId   String           @db.ObjectId
  lessonId    String?          @db.ObjectId

  answer      String?
  code        String?
  status      SubmissionStatus @default(PENDING)
  autoCorrect Boolean?         // true = verificare automată a trecut, false = nu, null = n/a
  grade       Int?             // 0-100
  feedback    String?

  gradedById  String?          @db.ObjectId
  gradedAt    DateTime?

  source      String?          // "lesson" | "random"
  difficulty  String?          // pentru random
  timeSpent   Int              @default(0)

  // Sistem de încercări/hint/rezolvare
  attemptNumber  Int     @default(1) // a câta încercare la această problemă
  hintUsed       Boolean @default(false) // hint a fost văzut înainte de submit
  solutionViewed Boolean @default(false) // elevul a apăsat „Vezi rezolvarea" (forțează 0p)
  locked         Boolean @default(false) // problemă blocată — nu se mai poate reîncerca

  // AI grading (pentru CODING) — profesorul virtual „Mr. PyWeb"
  aiGraded         Boolean  @default(false)
  aiReasoning      String?  // explicație pedagogică pentru elev (markdown)
  aiRubric         Json?    // {correctness, style, efficiency} cu scoruri 0-100
  aiSuspectedAi    Boolean  @default(false)
  aiSuspicionScore Int?     // 0-100, cât de probabil e că a folosit AI
  aiTokensIn       Int?     // pentru tracking cost
  aiTokensOut      Int?
  teacherOverride  Boolean  @default(false) // profesorul a suprascris nota AI
  xpAwarded        Int?     // XP efectiv acordat pentru această submisie

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  student     Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  problem     Problem          @relation(fields: [problemId], references: [id], onDelete: Cascade)
  lesson      Lesson?          @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([studentId, status])
  @@index([status, createdAt])
  @@index([lessonId])
  @@map("problem_submissions")
}

enum SubmissionStatus {
  PENDING        // așteaptă feedback profesor
  GRADED         // notată (trecută)
  NEEDS_REVISION // profesorul cere refacere
}

// ==================== AI USAGE TRACKING ====================
// Tracking pentru rate limit + cost al apelurilor către OpenAI (Mr. PyWeb)

model AiUsage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId   String?  @db.ObjectId
  ip          String?  // pentru rate-limit dacă nu e student logat
  endpoint    String   // "grade-code" | "explain" | "detect-ai" | etc.
  tokensIn    Int      @default(0)
  tokensOut   Int      @default(0)
  costUsd     Float    @default(0) // cost estimat pentru această cerere
  success     Boolean  @default(true)
  errorMsg    String?
  createdAt   DateTime @default(now())

  @@index([studentId, createdAt])
  @@index([ip, createdAt])
  @@index([createdAt])
  @@map("ai_usage")
}

// Chat istoric: elev ↔ Mr. PyWeb (clarificări la o problemă)
model AiChatMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId String   @db.ObjectId
  problemId String   @db.ObjectId
  lessonId  String?  @db.ObjectId
  role      String   // "user" | "assistant"
  content   String
  tokensIn  Int?
  tokensOut Int?
  createdAt DateTime @default(now())

  @@index([studentId, problemId, createdAt])
  @@index([createdAt])
  @@map("ai_chat_messages")
}

// ==================== LEARNING APP PAYMENTS ====================
// Plata pentru abonament la aplicația /learn (separat de plata pentru lecții la cursuri)

model LearningPayment {
