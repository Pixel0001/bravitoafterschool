// ==================== COSMETICS ====================

enum CosmeticType {
  THEME
  PROFILE_BANNER
  USERNAME_COLOR
  ANIMATED_FRAME
  LEADERBOARD_EFFECT
  ENTRY_EFFECT
  CODING_AURA
  TITLE
  PET
  RARE_COSMETIC
  ANIMATED_BACKGROUND
  PARTICLE_EFFECT
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum Currency {
  COINS
  GEMS
}

model Cosmetic {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  description   String?
  type          CosmeticType
  rarity        Rarity        @default(COMMON)
  currency      Currency      @default(COINS)
  price         Int           @default(0)         // 0 = gratuit / doar din chest
  imageUrl      String?
  previewUrl    String?
  cssPayload    Json?         // pentru THEME/colors/animations: {primary, secondary, gradient, glow, css}
  active        Boolean       @default(true)
  shopVisible   Boolean       @default(true)      // false = doar din chest-uri
  themeId       String?       @db.ObjectId        // dacă type=THEME, link la Theme
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  inventory     CosmeticInventory[]
  equipped      EquippedCosmetic[]
  chestRewards  ChestReward[]
  theme         Theme?        @relation(fields: [themeId], references: [id], onDelete: SetNull)

  @@index([type, active])
  @@index([rarity])
  @@map("cosmetics")
}

model CosmeticInventory {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  studentId   String    @db.ObjectId
  cosmeticId  String    @db.ObjectId
  acquiredAt  DateTime  @default(now())
  source      String?   // "shop" | "chest" | "leaderboard" | "admin"

  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  cosmetic    Cosmetic  @relation(fields: [cosmeticId], references: [id], onDelete: Cascade)

