// Prisma schema for PISchool - MongoDB

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==================== USER & AUTH ====================

model User {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  email             String    @unique
  password          String?   // null for Google-only users (Argon2id hash)
  name              String?
  phone             String?   // Număr de telefon (opțional)
  telegramChatId    String?   // Chat ID pentru notificări Telegram
  image             String?
  role              Role      @default(TEACHER)
  permissions       String[]  @default([]) // Granular permissions for ADMIN
  emailVerified     DateTime?
  active            Boolean   @default(true)
  superTeacher      Boolean   @default(false) // Profesor "super" - poate porni lecții la orice dată/oră, fără restricții de program
  
  // 2FA fields
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?   // Encrypted TOTP secret (AES-256-GCM)
  twoFactorSetupAt  DateTime? // When 2FA was enabled
  twoFactorAllowed  Boolean   @default(false) // Admin must allow 2FA for non-admin users
  
  // Password reset
  passwordResetToken    String?
  passwordResetExpires  DateTime?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  teacherGroups     Group[]           @relation("TeacherGroups")
  makeupLessons     MakeupLesson[]    @relation("TeacherMakeups")
  notifications     Notification[]    @relation("UserNotifications")
  sessions          AuthSession[]     @relation("UserSessions")
  backupCodes       BackupCode[]      @relation("UserBackupCodes")
  trustedDevices    TrustedDevice[]   @relation("UserTrustedDevices")
  auditLogs         AuditLog[]        @relation("UserAuditLogs")
  createdStudents   Student[]         @relation("CreatedStudents")
  createdPayments   Payment[]         @relation("CreatedPayments")
  createdProblems   Problem[]         @relation("CreatedProblems")
  createdSets       GeneratedSet[]    @relation("CreatedSets")
  bonusPointsAdded  BonusPoint[]      @relation("BonusPointsAdded")

  @@map("users")
}

enum Role {
  SUPERADMIN
  ADMIN
  TEACHER
}

// ==================== AUTH SESSIONS ====================

model AuthSession {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String    @db.ObjectId
  token           String    @unique // Session token hash
  deviceId        String?   // Device identifier
  ipAddress       String?
  userAgent       String?
  
  // 2FA state
  twoFactorVerified Boolean   @default(false)
  recent2faAt       DateTime? // Last step-up 2FA verification
  
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  user            User      @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

// ==================== BACKUP CODES ====================

model BackupCode {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  codeHash  String    // Hashed backup code
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  
  // Relations
  user      User      @relation("UserBackupCodes", fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("backup_codes")
}

// ==================== TRUSTED DEVICES ====================

model TrustedDevice {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  deviceId    String    // Device cookie/fingerprint
  name        String?   // Device name/description
  ipAddress   String?
  userAgent   String?
  lastUsedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  
  // Relations
  user        User      @relation("UserTrustedDevices", fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, deviceId])
  @@index([userId])
  @@map("trusted_devices")
}

// ==================== RATE LIMITING ====================

model RateLimitBucket {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  key         String    @unique // email:action or ip:action or deviceId:action
  action      String    // "login", "2fa", "forgot", "stepup"
  count       Int       @default(0)
  firstAttempt DateTime @default(now())
  lastAttempt DateTime  @default(now())
  lockedUntil DateTime?
  
  @@index([lockedUntil])
  @@map("rate_limit_buckets")
}

// ==================== STEP-UP TOKENS ====================

model StepUpToken {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  tokenHash   String    @unique
  userId      String    @db.ObjectId
  action      String    // "createUser", "changeRole", "export", "delete"
  ipAddress   String?
  deviceId    String?
  used        Boolean   @default(false)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  
  @@index([expiresAt])
  @@map("step_up_tokens")
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  action      String    // "login", "login_failed", "2fa_setup", "2fa_verify", "create_user", "change_role", "export", "delete", etc.
  actorId     String?   @db.ObjectId // User who performed the action (null for anonymous)
  targetId    String?   // Target resource ID (userId, resourceId, etc.)
  targetType  String?   // "user", "course", "group", etc.
  ipAddress   String?
  deviceId    String?
  userAgent   String?
  details     Json?     // Additional details (changes, before/after, etc.)
  severity    String    @default("info") // "info", "warning", "critical"
  success     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  
  // Relations
  actor       User?     @relation("UserAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)
  
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([severity])
  @@map("audit_logs")
}

// ==================== SECURITY ALERTS ====================

model SecurityAlert {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  type        String    // "brute_force", "suspicious_login", "2fa_disabled", "admin_created", etc.
  severity    String    @default("warning") // "warning", "critical"
  title       String
  message     String
  details     Json?
  ipAddress   String?
  userId      String?   @db.ObjectId
  acknowledged Boolean  @default(false)
  acknowledgedBy String? @db.ObjectId
  acknowledgedAt DateTime?
  sentVia     String[]  @default([]) // ["telegram", "email"]
  createdAt   DateTime  @default(now())
  
  @@index([type])
  @@index([severity])
  @@index([acknowledged])
  @@index([createdAt])
  @@map("security_alerts")
}

// ==================== CAPTCHA STATE ====================

model CaptchaState {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  key         String    @unique // email or ip
  failures    Int       @default(0)
  requiresCaptcha Boolean @default(false)
  lastFailure DateTime?
  createdAt   DateTime  @default(now())
  
  @@map("captcha_states")
}

// ==================== COURSES ====================

model Course {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  slug             String    @unique
  descriptionShort String
  descriptionLong  String?
  category         String?
  level            String?   // "Începător", "Intermediar", "Avansat"
  ageMin           Int?
  ageMax           Int?
  duration         String?   // "60 min", "90 min"
  lessonsCount     Int?
  price            Float     @default(0)
  discountPrice    Float?    // Prețul redus (opțional)
  seatsTotal       Int       @default(10)
  active           Boolean   @default(true)
  imageUrl         String?   // Imagine principală (deprecated, se folosește mainImageUrl)
  mainImageUrl     String?   // Imaginea principală selectată
  images           String[]  // Array de URL-uri pentru toate imaginile
  textReviews      Json?     // [{ author, role, text, rating, date }]
  faq              Json?     // [{ question, answer }]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  enrollments Enrollment[]
  groups      Group[]
  reviews     Review[]
  problems    Problem[]

  @@map("courses")
}

// ==================== BLOG ====================

model Blog {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  title             String
  slug              String   @unique
  excerpt           String?  // Scurtă descriere pentru listing/SEO
  coverImage        String?  // Imagine principală
  content           Json?    // Array de blocuri: [{type:'text'|'image'|'youtube'|'faq'|'heading'|'quote', ...}]
  category          String?
  tags              String[]
  recommendedCourseIds  String[] @db.ObjectId
  recommendedBlogSlugs  String[] // sluguri pentru bloguri recomandate manual
  published         Boolean  @default(true)
  publishedAt       DateTime @default(now())
  seoTitle          String?
  seoDescription    String?
  readMinutes       Int?     // estimat
  authorName        String?
  views             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([published, publishedAt])
  @@map("blogs")
}

// ==================== ENROLLMENTS (LEADS) ====================

model Enrollment {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  courseId      String           @db.ObjectId
  studentName   String
  studentAge    Int?
  parentName    String
  parentPhone   String
  parentEmail   String
  city          String?
  observations  String?
  status        EnrollmentStatus @default(NEW)
  notes         String?          // Legacy - kept for backwards compatibility
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  course        Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollmentNotes EnrollmentNote[] @relation("EnrollmentNotes")

  @@map("enrollments")
}

model EnrollmentNote {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  enrollmentId String?  @db.ObjectId
  inscriereId  String?  @db.ObjectId
  content      String
  createdAt    DateTime @default(now())
  
  // Relations
  enrollment   Enrollment? @relation("EnrollmentNotes", fields: [enrollmentId], references: [id], onDelete: Cascade)
  inscriere    Inscriere?  @relation("InscriereNotes", fields: [inscriereId], references: [id], onDelete: Cascade)
  
  @@map("enrollment_notes")
}

enum EnrollmentStatus {
  LEAD              // 🔵 Lead
  FARA_RASPUNS      // 🔘 Fără Răspuns
  CONTACTAT         // 🟡 Contactat
  PROGRAMAT         // 🟠 Programat
  PRIMA_LECTIE      // 🟢 Prima Lecție
  FINALIZAT_LECTIA  // ⚫ Finalizat Lecția
  SE_GANDESTE       // 🔘 Se Gândește
  ASTEPTAM_PLATA    // 💵 Așteptăm Plata
  PLATIT            // 💰 Plătit
  STUDIAZA          // 🟣 Studiază
  PLECAT            // 🔴 Plecat
  LOST_LEAD         // ❌ Lost Lead
  TEST              // 🧪 Test
  // Legacy statuses for backwards compatibility
  NEW
  CONTACTED
  CONFIRMED
  REJECTED
}

// ==================== STUDENTS ====================

model Student {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  fullName     String
  age          Int?
  parentName   String?
  parentPhone  String?
  parentEmail  String?
  notes        String?
  accessToken  String?  // token persistent pentru portalul elevului /learn/[token] (unique enforced in app code)
  password     String?  // hash parolă opțional pentru autentificare alternativă (Argon2id)
  active       Boolean  @default(true) // dacă e false, /learn/[token] returnează acces interzis
  superStudent Boolean  @default(false) // Super elev — accesează orice lecție din orice modul, indiferent de progres
  grade        Int?     // Clasa elevului (1-9); null = nespecificată

  // Limite per-elev (override peste grupă/global; null = folosește valoarea super-setării)
  cooldownOverrideMin Int?     // în minute, null = moștenește de la grupă/global
  dailyXpCapOverride  Int?     // în puncte XP, null = moștenește
  cooldownDisabled    Boolean  @default(false) // dezactivează explicit cooldown pentru acest elev
  xpCapDisabled       Boolean  @default(false) // dezactivează explicit cap-ul de XP
  lastProblemSolvedAt DateTime? // pentru calcul cooldown
  lastSolvedLessonId  String?   // lecția în care s-a rezolvat ultima problemă (cooldown per lecție)

  // Single-session enforcement: doar 1 browser activ per cont la /learn/[token]
  activeSessionId  String?   // ID-ul ultimului browser care a făcut „claim"
  activeSessionAt  DateTime? // când a fost ultima dată activ
  activeSessionIp  String?   // IP-ul (informativ, pentru audit)
  activeSessionUA  String?   // User-Agent (informativ, pentru audit)

  createdById  String?  @db.ObjectId // ID-ul userului care a creat elevul (profesor sau admin)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  createdBy            User?     @relation("CreatedStudents", fields: [createdById], references: [id], onDelete: SetNull)
  groupStudents        GroupStudent[]
  attendances          Attendance[]
  lessonTransactions   LessonTransaction[]
  makeupLessonStudents MakeupLessonStudent[]
  notifications        Notification[]
  problemAttempts      ProblemAttempt[]
  generatedSets        GeneratedSet[]
  moduleAccesses       ModuleAccess[]
  moduleAdvances       ModuleAdvance[]
  hiddenModules        ModuleHidden[]
  lessonAccesses       LessonAccess[]
  lessonProgresses     LessonProgress[]
  problemSubmissions   ProblemSubmission[]
  learningPayments     LearningPayment[]
  bonusPoints          BonusPoint[]

  // Gamification 2.0
  economy              StudentEconomy?
  streak               StudentStreak?
  inventory            CosmeticInventory[]
  equipped             EquippedCosmetic[]
  chestOpenings        ChestOpening[]
  leaderboardEntries   LeaderboardEntry[]
  rewardClaims         RewardClaim[]
  activeThemeId        String?            @db.ObjectId

  @@index([createdById])
  @@index([accessToken])
  @@index([active])
  @@map("students")
}

// ==================== BONUS POINTS ====================

model BonusPoint {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId String   @db.ObjectId
  points    Int
  reason    String
  addedById String   @db.ObjectId
  createdAt DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  addedBy   User     @relation("BonusPointsAdded", fields: [addedById], references: [id])

  @@index([studentId])
  @@map("bonus_points")
}

// ==================== SYSTEM SETTINGS (singleton) ====================
// Setări globale: cooldown probleme, cap XP zilnic, curba de niveluri.
// Doar UN singur rând în acest model (singleton); creat la primul GET dacă lipsește.

model SystemSettings {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId

  // Cooldown între rezolvarea a 2 probleme (în minute). Default 4h = 240 min.
  problemCooldownMin  Int      @default(240)
  cooldownEnabled     Boolean  @default(true)

  // Cap zilnic de XP per elev. Default 500 XP/zi.
  dailyXpCap          Int      @default(500)
  xpCapEnabled        Boolean  @default(true)

  // Curba de niveluri — array crescator de praguri XP. Index 0 = nivel 1.
  // Default progresie exponențială dificil de atins la niveluri mari.
  levelCurve          Int[]    @default([0, 100, 300, 700, 1500, 3000, 6000, 12000, 25000, 50000])
  levelNames          String[] @default(["Novice","Explorator","Practicant","Expert","Master","Legend","Mythic","Titan","Sage","Immortal"])

  updatedAt           DateTime @updatedAt
  updatedById         String?  @db.ObjectId

  @@map("system_settings")
}

// ==================== BRANCHES (FILIALE) ====================

model Branch {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique // "Centru", "Ciocana", "Botanica", etc.
  address   String?  // Adresa filialei (opțional)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  groups        Group[]
  makeupLessons MakeupLesson[]

  @@map("branches")
}

// ==================== GROUPS ====================

model Group {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  courseId        String   @db.ObjectId
  teacherId       String   @db.ObjectId
  branchId        String?  @db.ObjectId // Filiala (opțional)
  scheduleDays    String[] // ["Mon", "Wed"]
  scheduleTime    String?  // "18:00"
  locationType    String?  // "offline" / "online"
  locationDetails String?  // Sala/Link
  startDate       DateTime?
  active          Boolean  @default(true)

  // Limite per-grupă (override peste global; null = moștenește)
  cooldownOverrideMin Int?
  dailyXpCapOverride  Int?
  cooldownDisabled    Boolean @default(false)
  xpCapDisabled       Boolean @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  course              Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher             User                @relation("TeacherGroups", fields: [teacherId], references: [id], onDelete: Cascade)
  branch              Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  groupStudents       GroupStudent[]
  lessonSessions      LessonSession[]
  lessonTransactions  LessonTransaction[]
  makeupLessons       MakeupLesson[]
  missedSessions      MissedSession[]

  @@map("groups")
}

// ==================== GROUP-STUDENT PIVOT ====================

model GroupStudent {
  id               String             @id @default(auto()) @map("_id") @db.ObjectId
  groupId          String             @db.ObjectId
  studentId        String             @db.ObjectId
  lessonsRemaining Int                @default(0)
  absences         Int                @default(0)
  status           GroupStudentStatus @default(ACTIVE)
  statusNote       String?            // Motiv pentru plecare/pauză
  statusChangedAt  DateTime?          // Când s-a schimbat statusul
  enrolledAt       DateTime           @default(now())

  // Relations
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@unique([groupId, studentId])
  @@map("group_students")
}

enum GroupStudentStatus {
  ACTIVE       // Activ - participă la lecții
  PAUSED       // Pauză temporară
  LEFT         // A plecat din grupă
  COMPLETED    // A terminat cursul
  TRANSFERRED  // Transferat la altă grupă
}

// ==================== LESSON SESSIONS ====================

model LessonSession {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  groupId         String   @db.ObjectId
  date            DateTime
  notes           String?
  lessonsDeducted Boolean  @default(false)
  createdAt       DateTime @default(now())

  // Relations
  group               Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attendances         Attendance[]
  lessonTransactions  LessonTransaction[]

  @@map("lesson_sessions")
}

// ==================== ATTENDANCE ====================

model Attendance {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  sessionId String           @db.ObjectId
  studentId String           @db.ObjectId
  status    AttendanceStatus @default(ABSENT)
  notes     String?
  createdAt DateTime         @default(now())

  // Relations
  session LessonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@map("attendances")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

// ==================== LESSON TRANSACTIONS (AUDIT) ====================

model LessonTransaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId String   @db.ObjectId
  groupId   String   @db.ObjectId
  sessionId String?  @db.ObjectId
  delta     Int      // -1 for deduction, +1 for addition
  reason    String?
  createdAt DateTime @default(now())

  // Relations
  student Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group   Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  session LessonSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@map("lesson_transactions")
}

// ==================== MAKEUP LESSONS ====================

model MakeupLesson {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  groupId           String             @db.ObjectId
  teacherId         String             @db.ObjectId
  branchId          String?            @db.ObjectId  // Filiala (opțional)
  locationDetails   String?                          // Sala/Link
  scheduledAt       DateTime
  status            MakeupLessonStatus @default(SCHEDULED)
  notes             String?
  lessonsDeducted   Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  group           Group                 @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teacher         User                  @relation("TeacherMakeups", fields: [teacherId], references: [id], onDelete: Cascade)
  branch          Branch?               @relation(fields: [branchId], references: [id], onDelete: SetNull)
  students        MakeupLessonStudent[]

  @@map("makeup_lessons")
}

model MakeupLessonStudent {
  id             String                     @id @default(auto()) @map("_id") @db.ObjectId
  makeupLessonId String                     @db.ObjectId
  studentId      String                     @db.ObjectId
  status         MakeupLessonStudentStatus  @default(PENDING)
  notes          String?
  createdAt      DateTime                   @default(now())

  // Relations
  makeupLesson MakeupLesson @relation(fields: [makeupLessonId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([makeupLessonId, studentId])
  @@map("makeup_lesson_students")
}

enum MakeupLessonStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum MakeupLessonStudentStatus {
  PENDING
  PRESENT
  ABSENT
}

// ==================== REVIEWS ====================

model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  authorName String
  roleLabel  String?  // "Părinte", "Elev"
  rating     Int      @default(5) // 1-5
  message    String
  avatarUrl  String?
  courseId   String?  @db.ObjectId
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@map("reviews")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  type        NotificationType
  title       String
  message     String
  link        String?          // URL pentru acțiune (ex: /admin/students/123)
  recipientId String?          @db.ObjectId // User ID (profesor/admin) sau null pentru toți adminii
  studentId   String?          @db.ObjectId // Elev relevant (opțional)
  groupId     String?          @db.ObjectId // Grupă relevantă (opțional)
  data        Json?            // Date adiționale (lessonsRemaining, etc.)
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  // Relations
  recipient User?    @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([recipientId, read])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  TEACHER_DAILY_SCHEDULE  // Profesorul are lecții azi
  LOW_LESSONS            // Elev cu puține lecții (sub 3)
  ZERO_LESSONS           // Elev cu 0 lecții
  NEGATIVE_LESSONS       // Elev cu lecții negative
  PAYMENT_RECEIVED       // Plată primită
  NEW_ENROLLMENT         // Înscriere nouă
  MISSED_SESSION         // Lecție ratată
  LATE_SESSION           // Lecție nepornită (2+ ore întârziere)
  CANCELLED_SESSION      // Lecție anulată de profesor
  REVISION_REQUEST       // Profesorul a cerut refacerea unei probleme
}

// ==================== PAYMENTS ====================

model Payment {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  groupStudentId String?       @db.ObjectId  // Opțional: rămâne NULL dacă elevul/grupa au fost șterse
  amount         Float         // Suma achitată (RON)
  paymentDate    DateTime      @default(now())
  paymentMethod  String?       // "cash", "card", "transfer"
  notes          String?       // Notițe adiționale
